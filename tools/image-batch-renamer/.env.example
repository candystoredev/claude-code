# Password to access the webapp. Set this in Railway environment variables.
APP_PASSWORD=

# Optional: Flask secret key for session signing. Railway auto-generates one if omitted.
SECRET_KEY=

# Cloud storage pre-configuration (optional)
# When set, the credentials form is hidden and uploads go straight to the configured bucket.
# Set STORAGE_TYPE to "r2" or "s3" (default: r2)
STORAGE_TYPE=r2

# Cloudflare R2 (required if STORAGE_TYPE=r2)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_PUBLIC_BASE_URL=
R2_FOLDER_PREFIX=

# AWS S3 (required if STORAGE_TYPE=s3)
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
S3_FOLDER_PREFIX=
S3_REGION=us-east-1
